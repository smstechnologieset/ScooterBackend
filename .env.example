NODE_ENV=development
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=3000
TCP_HOST=0.0.0.0
TCP_PORT=7000

DATABASE_URL=postgresql://scooter:scooter@localhost:5432/scooter_lock?schema=public
JWT_SECRET=replace-with-a-long-random-secret

TCP_MAX_FRAME_BYTES=2048
HEARTBEAT_TIMEOUT_MS=180000
COMMAND_TIMEOUT_MS=15000
COMMAND_RETRY_ATTEMPTS=2
COMMAND_RETRY_BACKOFF_MS=1000

PROTOCOL_VERSION=G168
PROTOCOL_FIELD_SEPARATOR=#
PROTOCOL_PACKET_TERMINATOR=$
PROTOCOL_ACK_PREFIX=ACK^
PROTOCOL_ACK_TERMINATOR=

# Keep these as "unspecified" until the manufacturer confirms exact behavior.
PROTOCOL_INBOUND_LENGTH_MODE=unspecified
PROTOCOL_OUTBOUND_LENGTH_MODE=unspecified
PROTOCOL_OUTBOUND_LENGTH_LITERAL=
PROTOCOL_CHECKSUM_MODE=unspecified
PROTOCOL_INBOUND_ACK_MODE=ack-prefix-command
PROTOCOL_OUTBOUND_ACK_MODE=unspecified
PROTOCOL_DUPLICATE_PACKET_MODE=record-only
PROTOCOL_AUTH_FLOW=unspecified
